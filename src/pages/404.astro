---
import Base from '../layouts/Base.astro';
import { waLink, WHATSAPP_MESSAGES } from '../lib/site';
---

<Base
  title="Fuera de la cancha — Página no encontrada"
  description="La página que buscas salió de la cancha. Vuelve al inicio o conversa con el equipo GSM."
  noindex
>
  <section class="nf bg-ink">
    <div class="container-x nf__inner">
      <p class="eyebrow">Error 404</p>
      <h1 class="nf__title font-display-narrow" data-split>
        Esta jugada se fue <em class="font-serif-italic text-orange">fuera de la cancha</em>.
      </h1>
      <p class="nf__lead">
        La página que buscas no existe, fue movida o nunca estuvo en el roster. Volvamos al juego.
      </p>
      <div class="nf__score font-mono">
        <span>15</span><span>·</span><span>30</span><span>·</span><span>40</span><span>·</span><span class="nf__game">404</span>
      </div>
      <div class="nf__cta">
        <a class="btn btn-primary" data-magnetic href="/">Volver al inicio</a>
        <a class="btn btn-outline" href={waLink(WHATSAPP_MESSAGES.default)} target="_blank" rel="noopener">Escribir por WhatsApp</a>
      </div>
      <ul class="nf__links">
        <li><a href="/servicios">Servicios</a></li>
        <li><a href="/atletas">Atletas</a></li>
        <li><a href="/nosotros">Nosotros</a></li>
        <li><a href="/contacto">Contacto</a></li>
      </ul>
    </div>
  </section>

  <style>
    .nf { min-height: 100vh; display: grid; place-items: center; padding-block: calc(var(--spacing-section) + 4rem); }
    .nf__inner { display: grid; gap: 1.4rem; max-width: 60rem; text-align: left; }
    .nf__title { font-size: clamp(1.7rem, 3.2vw, 2.8rem); line-height: 1.15; letter-spacing: -0.02em; margin: 0.4rem 0 0.6rem; max-width: 22ch; }
    .nf__lead { color: rgba(242,239,232,0.78); font-size: 0.95rem; max-width: 52ch; line-height: 1.6; }
    .nf__score { display: flex; gap: 0.8rem; font-size: 0.86rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-orange); margin: 1rem 0 1.4rem; }
    .nf__game { color: var(--color-bone); }
    .nf__cta { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.6rem; }
    .nf__links { list-style: none; padding: 0; display: flex; gap: 1.6rem; flex-wrap: wrap; font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; border-top: 1px solid var(--color-line); padding-top: 1.4rem; }
    .nf__links a { color: rgba(242,239,232,0.7); transition: color 0.3s; }
    .nf__links a:hover { color: var(--color-orange); }
  </style>
</Base>
