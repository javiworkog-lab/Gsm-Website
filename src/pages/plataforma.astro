---
import Base from '../layouts/Base.astro';
import { SITE, waLink, WHATSAPP_MESSAGES } from '../lib/site';

const breadcrumbs = [
  { name: 'Inicio', url: SITE.url },
  { name: 'Plataforma', url: `${SITE.url}/plataforma` },
];

// 5 pilares del Perfil del Atleta Integral (PAI)
const pillars = [
  { code: 'P1', name: 'Rendimiento', body: 'Capacidades técnicas, tácticas y competitivas. El núcleo deportivo medible.' },
  { code: 'P2', name: 'Salud',       body: 'Bienestar físico, prevención y recuperación. Lo que sostiene el rendimiento en el tiempo.' },
  { code: 'P3', name: 'Mentalidad',  body: 'Gestión emocional, resiliencia y enfoque. La capa que define carreras largas.' },
  { code: 'P4', name: 'Educación',   body: 'Aprendizaje, cultura y desarrollo intelectual. El atleta crece como persona.' },
  { code: 'P5', name: 'Identidad',   body: 'Valores, comunicación e impacto humano. Quién es el atleta más allá del resultado.' },
];

// Las 3 vistas del Espejo Inteligente
const views = [
  { tag: 'Vista Atleta',  body: 'Su propio reflejo: estado actual, evolución por pilar, próximas acciones y feedback simple y honesto.' },
  { tag: 'Vista Coach',   body: 'Lectura del grupo: cargas, alertas tempranas, conversaciones por pilar y decisiones apoyadas en datos.' },
  { tag: 'Vista Admin',   body: 'Lectura institucional: programa completo, comunidades, inversión y correlación entre recursos y crecimiento.' },
];

// 9 Módulos de la plataforma
const modules = [
  { code: '01', name: 'Perfil del Atleta Integral', body: 'PAI dinámico organizado en 5 pilares que evoluciona con cada registro diario.' },
  { code: '02', name: 'Check-in diario',           body: 'Diseñado para completarse en menos de 90 segundos. Consistencia sobre profundidad.' },
  { code: '03', name: 'Planificación',             body: 'Macro temporada · Meso mensual · Micro semanal. Cada tarea conectada a un objetivo.' },
  { code: '04', name: 'Comunicación entre actores',body: 'Red estructurada por pilar y rol. Conversaciones contextualizadas, no chats sueltos.' },
  { code: '05', name: 'AREF',                      body: '52 ciclos de mejora por año. Cada fase tiene un día, un actor y una acción concreta.' },
  { code: '06', name: 'Dashboard Espejo Inteligente', body: 'La capa de visualización que vuelve visible lo invisible. Tres vistas según rol.' },
  { code: '07', name: 'Social',                    body: 'Feed de progreso interno y perfil público compartible. Privacidad por default.' },
  { code: '08', name: 'Institucional',             body: 'Director, head coach, entrenador, apoderado y atleta. Los mismos datos desde 5 perspectivas.' },
  { code: '09', name: 'Financiero',                body: 'Inversión mensual por categoría, modelo de donaciones y correlación con crecimiento del PAI.' },
];

// Roles del ecosistema
const roles = [
  { tag: 'Atleta',     body: 'Controla qué datos comparte y puede revocar acceso a cualquier especialista.' },
  { tag: 'Coach',      body: 'Ve todos los pilares de sus atletas y todas las conversaciones del programa.' },
  { tag: 'Especialista', body: 'Solo ve el pilar derivado. Sin acceso cruzado sin consentimiento.' },
  { tag: 'Institución', body: 'Director, head coach, apoderados: cada rol con su propia lectura institucional.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Plataforma GSM',
  applicationCategory: 'SportsApplication',
  operatingSystem: 'Web',
  description: 'Plataforma de desarrollo deportivo integral con Perfil del Atleta Integral (PAI), Dashboard Espejo Inteligente, metodología AREF y 9 módulos integrados.',
  provider: { '@type': 'Organization', name: 'GSM — Game · Set...Match', url: SITE.url },
  audience: { '@type': 'Audience', audienceType: 'Atletas, clubes, federaciones, colegios e instituciones deportivas' },
};
---

<Base
  title="Plataforma GSM — Análisis de Datos Inteligente y Dashboard Espejo"
  description="La plataforma de GSM integra el Perfil del Atleta Integral, el Dashboard Espejo Inteligente, la metodología AREF y 9 módulos en un solo ecosistema."
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="plat-hero bg-ink">
    <div class="container-x plat-hero__inner">
      <p class="eyebrow">Plataforma GSM</p>
      <h1 class="plat-hero__title font-display-narrow" data-split>
        Análisis de Datos <em class="font-serif-italic text-orange">Inteligente</em>.
      </h1>
      <p class="plat-hero__lead">
        Un ecosistema colaborativo que desarrolla atletas integrales a través de <strong>metodología, datos, educación y acompañamiento humano</strong>. La plataforma integra los cinco pilares del atleta, el dashboard espejo inteligente y los nueve módulos operativos en un solo lugar.
      </p>
      <div class="plat-hero__cta">
        <a class="btn btn-primary" data-magnetic href={waLink(WHATSAPP_MESSAGES.prevention)} target="_blank" rel="noopener">Solicitar demo</a>
        <a class="btn btn-outline" data-magnetic href="#modulos">Ver los 9 módulos</a>
      </div>
    </div>
    <div class="plat-hero__macro" aria-hidden="true"><span>P</span></div>
  </section>

  <!-- ESPEJO INTELIGENTE -->
  <section class="mirror bg-court">
    <div class="container-x mirror__inner">
      <header class="mirror__head">
        <p class="eyebrow" data-reveal>Capa de visualización</p>
        <h2 class="mirror__title font-display-narrow" data-split>
          El <em class="font-serif-italic text-orange">Espejo Inteligente</em>.
        </h2>
        <p class="mirror__lead" data-reveal style="--reveal-delay:120ms">
          Es el dashboard que refleja el estado completo del atleta y del programa: cuerpo, carga, mentalidad, identidad, recursos. Una sola lectura, tres vistas según rol, actualización continua. Hace visible lo que normalmente es invisible.
        </p>
      </header>

      <div class="mirror__grid">
        {views.map((v, i) => (
          <article class="view" data-reveal style={`--reveal-delay:${i * 130}ms`}>
            <p class="view__tag font-mono">{v.tag}</p>
            <p class="view__body">{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PAI - 5 PILARES -->
  <section class="pai bg-bone">
    <div class="container-x">
      <header class="pai__head">
        <p class="eyebrow" data-reveal>Perfil del Atleta Integral · PAI</p>
        <h2 class="pai__title font-display-narrow" data-split>
          Cinco pilares que <em class="font-serif-italic text-orange">evolucionan</em> con cada registro.
        </h2>
        <p class="pai__lead" data-reveal style="--reveal-delay:120ms">
          El PAI es el corazón de la plataforma: un perfil dinámico que crece con el atleta. No es una ficha estática: es un mapa vivo que ordena cinco dimensiones y permite leerlas en conjunto.
        </p>
      </header>

      <div class="pai__grid">
        {pillars.map((p, i) => (
          <article class="pillar-card" data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <p class="pillar-card__code font-mono">{p.code}</p>
            <h3 class="pillar-card__name font-display-narrow">{p.name}</h3>
            <p class="pillar-card__body">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 9 MÓDULOS -->
  <section class="modules bg-ink" id="modulos">
    <div class="container-x">
      <header class="modules__head">
        <p class="eyebrow" data-reveal>Estructura técnica</p>
        <h2 class="modules__title font-display-narrow" data-split>
          Nueve módulos, un mismo <em class="font-serif-italic text-orange">ecosistema</em>.
        </h2>
        <p class="modules__lead" data-reveal style="--reveal-delay:120ms">
          La plataforma se organiza en nueve módulos integrados que cubren el desarrollo individual del atleta, la metodología, la vida institucional y la dimensión social y financiera.
        </p>
      </header>

      <div class="modules__grid">
        {modules.map((m, i) => (
          <article class="mod-card" data-reveal style={`--reveal-delay:${i * 70}ms`}>
            <p class="mod-card__code font-display-narrow">{m.code}</p>
            <h3 class="mod-card__name font-display-narrow">{m.name}</h3>
            <p class="mod-card__body">{m.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- AREF -->
  <section class="aref bg-bone">
    <div class="container-x aref__inner">
      <div class="aref__col">
        <p class="eyebrow" data-reveal>Metodología AREF</p>
        <h2 class="aref__title font-display-narrow" data-split>
          52 ciclos de mejora <em class="font-serif-italic text-orange">al año</em>.
        </h2>
      </div>
      <div class="aref__col">
        <p class="aref__body" data-reveal>
          AREF es la metodología operativa de GSM: un ciclo semanal continuo donde cada fase tiene un día, un actor y una acción concreta. No son planificaciones de PowerPoint: son rutinas que ocurren todas las semanas, con responsable definido y registro en la plataforma.
        </p>
        <p class="aref__body" data-reveal style="--reveal-delay:120ms">
          El resultado: cincuenta y dos oportunidades por temporada para ajustar, aprender y crecer — en cancha, en salud, en cabeza, en estudios y en identidad.
        </p>
      </div>
    </div>
  </section>

  <!-- ROLES Y PRIVACIDAD -->
  <section class="roles bg-court-deep">
    <div class="container-x">
      <header class="roles__head">
        <p class="eyebrow" data-reveal>Roles · Privacidad</p>
        <h2 class="roles__title font-display-narrow" data-split>
          Un ecosistema con <em class="font-serif-italic text-orange">reglas claras</em>.
        </h2>
        <p class="roles__lead" data-reveal style="--reveal-delay:120ms">
          La privacidad es el default, no la excepción. Cada rol del ecosistema ve exactamente lo que necesita ver para hacer su trabajo, ni más, ni menos. El atleta siempre controla el acceso a su propia información.
        </p>
      </header>

      <div class="roles__grid">
        {roles.map((r, i) => (
          <article class="role" data-reveal style={`--reveal-delay:${i * 110}ms`}>
            <p class="role__tag font-mono">{r.tag}</p>
            <p class="role__body">{r.body}</p>
          </article>
        ))}
      </div>

      <aside class="roles__note">
        <p class="roles__note-eye font-mono">Sobre el alcance clínico</p>
        <p class="roles__note-body">
          <strong>GSM no es una clínica.</strong> La plataforma no diagnostica, no indica tratamiento ni reemplaza al equipo médico del atleta. Es una capa de análisis e interpretación que se apoya siempre en el criterio clínico del profesional tratante.
        </p>
      </aside>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="plat-cta bg-bone">
    <div class="container-narrow plat-cta__inner">
      <p class="eyebrow" data-reveal>Conversemos</p>
      <h2 class="plat-cta__title font-display-narrow" data-split>
        Veámosla <em class="font-serif-italic text-orange">funcionando</em>.
      </h2>
      <p class="plat-cta__body" data-reveal>
        Coordinamos una demo personalizada según el momento de tu institución, atleta o proyecto. Tres a cinco preguntas en común, un recorrido por la plataforma y una propuesta de implementación a medida.
      </p>
      <div class="plat-cta__row">
        <a class="btn btn-primary" data-magnetic href={waLink(WHATSAPP_MESSAGES.prevention)} target="_blank" rel="noopener">Solicitar demo por WhatsApp</a>
        <a class="btn btn-outline btn-outline--dark" data-magnetic href="/contacto">Coordinar reunión</a>
      </div>
    </div>
  </section>

  <style>
    /* ----- HERO ----- */
    .plat-hero {
      padding-block: calc(var(--spacing-section) + 3.5rem) calc(var(--spacing-section) - 1rem);
      position: relative;
      overflow: hidden;
    }
    .plat-hero__inner { position: relative; z-index: 2; }
    .plat-hero__title { font-size: var(--title-h1); line-height: 1.1; letter-spacing: -0.025em; margin: 0.8rem 0 1.2rem; max-width: 22ch; }
    .plat-hero__lead { max-width: 62ch; color: rgba(242,239,232,0.82); font-size: var(--title-lead); line-height: 1.6; margin: 0 0 1.6rem; }
    .plat-hero__lead strong { color: var(--color-bone); font-weight: 600; }
    .plat-hero__cta { display: flex; gap: 0.7rem; flex-wrap: wrap; }
    .plat-hero__cta .btn { min-width: 12rem; justify-content: center; }
    .plat-hero__macro {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      overflow: hidden;
    }
    .plat-hero__macro span {
      font-family: var(--font-display);
      font-weight: 900;
      font-style: italic;
      font-size: clamp(20rem, 45vw, 36rem);
      line-height: 0.78;
      letter-spacing: -0.06em;
      color: var(--color-bone);
      opacity: 0.04;
      transform: translateX(10%) rotate(-4deg);
      user-select: none;
    }

    /* ----- ESPEJO INTELIGENTE ----- */
    .mirror { padding-block: var(--spacing-section); background: var(--color-court); color: var(--color-bone); overflow: hidden; }
    .mirror__head { max-width: 60rem; display: grid; gap: 0.9rem; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
    .mirror__head .eyebrow { color: var(--color-orange); }
    .mirror__title { font-size: var(--title-h2); line-height: 1.1; letter-spacing: -0.025em; margin: 0; max-width: 22ch; }
    .mirror__lead { max-width: 60ch; color: rgba(242,239,232,0.82); font-size: var(--title-lead); line-height: 1.65; margin: 0; }
    .mirror__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      border-top: 1px solid rgba(242,239,232,0.18);
      border-bottom: 1px solid rgba(242,239,232,0.18);
    }
    @media (max-width: 900px) { .mirror__grid { grid-template-columns: 1fr; } }
    .view {
      padding: 1.8rem 1.4rem 2rem;
      border-right: 1px solid rgba(242,239,232,0.18);
      display: grid;
      gap: 0.55rem;
      align-content: start;
    }
    .view:last-child { border-right: 0; }
    @media (max-width: 900px) {
      .view { border-right: 0; border-bottom: 1px solid rgba(242,239,232,0.18); }
      .view:last-child { border-bottom: 0; }
    }
    .view__tag { font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-orange); margin: 0; }
    .view__body { font-size: 0.95rem; line-height: 1.6; color: rgba(242,239,232,0.85); margin: 0; }

    /* ----- PAI (5 PILARES) ----- */
    .pai { padding-block: var(--spacing-section); color: var(--color-ink); }
    .pai__head { max-width: 60rem; display: grid; gap: 0.9rem; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
    .pai__head .eyebrow { color: var(--color-orange); }
    .pai__title { font-size: var(--title-h2); line-height: 1.1; letter-spacing: -0.025em; margin: 0; max-width: 26ch; }
    .pai__lead { max-width: 58ch; color: rgba(10,10,10,0.72); font-size: var(--title-lead); line-height: 1.65; margin: 0; }
    .pai__grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: clamp(0.8rem, 1.5vw, 1.2rem);
    }
    @media (max-width: 1100px) { .pai__grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 700px)  { .pai__grid { grid-template-columns: 1fr; } }
    .pillar-card {
      background: var(--color-paper);
      border: 1px solid rgba(10,10,10,0.08);
      padding: 1.4rem 1.2rem 1.5rem;
      display: grid;
      gap: 0.45rem;
      align-content: start;
      min-height: 12rem;
    }
    .pillar-card__code { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-orange); margin: 0; }
    .pillar-card__name { font-size: var(--title-h3); letter-spacing: -0.02em; line-height: 1.1; margin: 0.15rem 0 0.2rem; }
    .pillar-card__body { font-size: 0.88rem; line-height: 1.55; color: rgba(10,10,10,0.72); margin: 0; }

    /* ----- 9 MÓDULOS ----- */
    .modules { padding-block: var(--spacing-section); color: var(--color-bone); }
    .modules__head { max-width: 60rem; display: grid; gap: 0.9rem; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
    .modules__head .eyebrow { color: var(--color-orange); }
    .modules__title { font-size: var(--title-h2); line-height: 1.1; letter-spacing: -0.025em; margin: 0; max-width: 22ch; }
    .modules__lead { max-width: 60ch; color: rgba(242,239,232,0.78); font-size: var(--title-lead); line-height: 1.65; margin: 0; }
    .modules__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(0.8rem, 1.5vw, 1.2rem);
    }
    @media (max-width: 900px) { .modules__grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .modules__grid { grid-template-columns: 1fr; } }
    .mod-card {
      padding: 1.5rem 1.3rem 1.6rem;
      border: 1px solid var(--color-line);
      background: rgba(242,239,232,0.03);
      display: grid;
      gap: 0.4rem;
      align-content: start;
      min-height: 12rem;
    }
    .mod-card__code { font-size: 1.6rem; line-height: 0.9; letter-spacing: -0.025em; color: var(--color-orange); margin: 0; }
    .mod-card__name { font-size: var(--title-h3); letter-spacing: -0.015em; line-height: 1.15; margin: 0.15rem 0 0.2rem; }
    .mod-card__body { font-size: 0.88rem; line-height: 1.55; color: rgba(242,239,232,0.78); margin: 0; }

    /* ----- AREF ----- */
    .aref { padding-block: var(--spacing-section); color: var(--color-ink); }
    .aref__inner { display: grid; grid-template-columns: 1fr 2fr; gap: clamp(2rem, 6vw, 5rem); align-items: start; }
    @media (max-width: 800px) { .aref__inner { grid-template-columns: 1fr; gap: 1.4rem; } }
    .aref__col .eyebrow { color: var(--color-orange); }
    .aref__title { font-size: var(--title-h2); letter-spacing: -0.025em; line-height: 1.1; margin: 0.6rem 0 0; max-width: 14ch; }
    .aref__body { font-size: 1rem; line-height: 1.7; color: rgba(10,10,10,0.78); margin: 0 0 1.2rem; max-width: 58ch; }
    .aref__body:last-child { margin-bottom: 0; }

    /* ----- ROLES ----- */
    .roles { padding-block: var(--spacing-section); }
    .roles__head { max-width: 60rem; display: grid; gap: 0.9rem; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
    .roles__head .eyebrow { color: var(--color-orange); }
    .roles__title { font-size: var(--title-h2); line-height: 1.1; letter-spacing: -0.025em; margin: 0; max-width: 22ch; }
    .roles__lead { max-width: 58ch; color: rgba(242,239,232,0.78); font-size: var(--title-lead); line-height: 1.65; margin: 0; }
    .roles__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: clamp(2rem, 3.5vw, 3rem);
    }
    @media (max-width: 900px) { .roles__grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .roles__grid { grid-template-columns: 1fr; } }
    .role {
      padding: 1.3rem 1.2rem;
      border: 1px solid var(--color-line);
      background: rgba(242,239,232,0.04);
      display: grid;
      gap: 0.45rem;
    }
    .role__tag { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-orange); margin: 0; }
    .role__body { font-size: 0.92rem; line-height: 1.55; color: rgba(242,239,232,0.82); margin: 0; }

    .roles__note {
      max-width: 60rem;
      border-left: 2px solid var(--color-orange);
      padding: 0.9rem 0 0.9rem 1.2rem;
      color: var(--color-bone);
    }
    .roles__note-eye { font-size: 0.66rem; letter-spacing: 0.22em; text-transform: uppercase; opacity: 0.65; margin: 0 0 0.5rem; }
    .roles__note-body { font-size: 0.92rem; line-height: 1.6; margin: 0; opacity: 0.85; }
    .roles__note-body strong { color: var(--color-bone); font-weight: 600; }

    /* ----- CTA FINAL ----- */
    .plat-cta { padding-block: var(--spacing-section); color: var(--color-ink); }
    .plat-cta__inner { display: grid; gap: 1rem; max-width: 56rem; text-align: center; justify-items: center; }
    .plat-cta__title { font-size: var(--title-h2); line-height: 1.1; letter-spacing: -0.025em; margin: 0.4rem 0 0.6rem; max-width: 22ch; }
    .plat-cta__body { font-size: var(--title-lead); line-height: 1.65; color: rgba(10,10,10,0.72); max-width: 56ch; margin: 0 0 1.4rem; }
    .plat-cta__row { display: flex; gap: 0.7rem; flex-wrap: wrap; justify-content: center; }
    .plat-cta__row .btn { min-width: 13rem; justify-content: center; }
    .btn-outline--dark { color: var(--color-ink); border-color: var(--color-ink); }
    .btn-outline--dark:hover { background: var(--color-ink); color: var(--color-bone); }
  </style>
</Base>
