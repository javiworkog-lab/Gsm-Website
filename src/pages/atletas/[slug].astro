---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { SITE, waLink, WHATSAPP_MESSAGES } from '../../lib/site';

export async function getStaticPaths() {
  const all = await getCollection('atletas');
  return all.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const data = entry.data;
const { Content } = await render(entry);

const breadcrumbs = [
  { name: 'Inicio', url: SITE.url },
  { name: 'Atletas', url: `${SITE.url}/atletas` },
  { name: data.name, url: `${SITE.url}/atletas/${entry.id}` },
];

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: data.name,
  jobTitle: data.discipline,
  image: data.photo,
  url: `${SITE.url}/atletas/${entry.id}`,
  worksFor: { '@type': 'Organization', name: 'GSM — Game · Set...Match' },
  knowsAbout: [data.category, data.discipline],
};
---

<Base
  title={`${data.name} — ${data.discipline} · Atleta GSM`}
  description={`${data.name}, atleta de ${data.discipline} representado por GSM. ${data.achievements[0]}.`}
  image={data.photo}
  jsonLd={personLd}
  breadcrumbs={breadcrumbs}
>
  <article class="athlete">
    <section class="athlete__hero">
      <div class="athlete__photo">
        <img src={data.photo} alt={`Retrato de ${data.name}, ${data.discipline}, atleta representado por GSM`} fetchpriority="high" />
        <span class="watermark">GAME · SET...MATCH</span>
      </div>
      <div class="container-x athlete__info">
        <p class="eyebrow">{data.category}</p>
        <h1 class="athlete__name font-display-narrow" data-split>{data.name}</h1>
        <p class="athlete__disc font-mono">{data.discipline}</p>
        {data.quote && (
          <blockquote class="athlete__quote font-serif-italic">"{data.quote}"</blockquote>
        )}
      </div>
    </section>

    <section class="bg-bone athlete__body">
      <div class="container-narrow grid-editorial">
        <div class="prose-editorial" style="grid-column: span 7;">
          <Content />
          <h2>Logros</h2>
          <ul>
            {data.achievements.map((a: string) => (<li>{a}</li>))}
          </ul>
          {data.sponsors && data.sponsors.length > 0 && (
            <>
              <h2>Sponsors activos</h2>
              <ul>
                {data.sponsors.map((s: string) => (<li>{s}</li>))}
              </ul>
            </>
          )}
        </div>
        <aside class="athlete__aside" style="grid-column: span 5;">
          <div class="athlete__card">
            <p class="eyebrow" style="color:var(--color-orange)">¿Quieres trabajar con {data.name.split(' ')[0]}?</p>
            <p>Para colaboraciones comerciales, sponsoring, charlas o entrevistas, escríbenos. Coordinamos todas las solicitudes desde GSM.</p>
            <div class="athlete__cta">
              <a class="btn btn-primary" data-magnetic href={waLink(WHATSAPP_MESSAGES.athletes)} target="_blank" rel="noopener">WhatsApp GSM</a>
              <a class="btn btn-outline" data-magnetic href="/contacto">Coordinar reunión</a>
            </div>
          </div>
        </aside>
      </div>
    </section>
  </article>

  <style>
    .athlete__hero { position: relative; min-height: 80svh; background: var(--color-ink); overflow: hidden; padding-bottom: 3rem; padding-top: 8rem; }
    .athlete__photo { position: absolute; inset: 0; }
    .athlete__photo img { width: 100%; height: 100%; object-fit: cover; filter: contrast(1.04) saturate(0.96); }
    .athlete__photo::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(10,10,10,0.5) 0%, rgba(10,10,10,0.2) 30%, rgba(10,10,10,0.95) 100%); }
    .athlete__info { position: relative; z-index: 2; padding-top: clamp(8rem, 25vh, 15rem); }
    .athlete__name { font-size: var(--title-h1); line-height: 1.1; letter-spacing: -0.025em; margin: 0.5rem 0 0.4rem; }
    .athlete__disc { font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.8; margin: 0 0 1.4rem; }
    .athlete__quote { max-width: 52ch; font-size: clamp(0.95rem, 1.3vw, 1.15rem); line-height: 1.55; margin: 0; opacity: 0.92; border-left: 3px solid var(--color-orange); padding-left: 1.2rem; }

    .athlete__body { padding-block: var(--spacing-section); color: var(--color-ink); }
    .athlete__body .prose-editorial { color: var(--color-ink); }
    .athlete__card { background: var(--color-ink); color: var(--color-bone); padding: 1.8rem 1.5rem; border: 1px solid var(--color-line); position: sticky; top: 6rem; display: grid; gap: 1rem; }
    .athlete__cta { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    @media (max-width: 800px) { .athlete__card { position: static; } }
  </style>
</Base>
