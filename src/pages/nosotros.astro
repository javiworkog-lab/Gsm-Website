---
import Base from '../layouts/Base.astro';
import Marquee from '../components/ui/Marquee.astro';
import Founders from '../components/sections/Founders.astro';
import { SITE, STATS } from '../lib/site';

const breadcrumbs = [
  { name: 'Inicio', url: SITE.url },
  { name: 'Nosotros', url: `${SITE.url}/nosotros` },
];

const values = [
  { num: '01', title: 'Honestidad antes que humo', body: 'Decimos lo que vemos. Si un proyecto no tiene futuro, lo decimos. Si lo tiene, lo trabajamos en serio.' },
  { num: '02', title: 'Método antes que improvisación', body: 'Cada decisión se toma con datos, contexto y métrica. La pasión está, pero no sustituye el análisis.' },
  { num: '03', title: 'Resultados antes que ruido', body: 'Lo que se mide, mejora. Lo que se publica sin medir, es marketing. GSM no hace marketing, hace gestión.' },
  { num: '04', title: 'Personas antes que números', body: 'Detrás de cada KPI hay un atleta, un dirigente, una familia, una institución. Esa es la razón de existir.' },
];

const manifestBlocks = [
  {
    num: '01',
    eyebrow: 'Origen',
    title: 'El por qué de GSM',
    body: 'Llevamos 12 años trabajando con clubes, federaciones, colegios, atletas y proyectos en Chile. Vimos siempre la misma película: mucho talento, poca metodología; mucha pasión, poca infraestructura; mucho voluntarismo, poca gestión. Decidimos cambiar eso y fundamos GSM.',
  },
  {
    num: '02',
    eyebrow: 'Servicios',
    title: 'Lo que hacemos',
    body: 'GSM trabaja en cuatro frentes: Sport Performance (instituciones), Athlete Management (deportistas), Educación (colegios y universidades) y Funding & Projects (proyectos deportivos). Cada servicio tiene metodología propia, métricas claras y un equipo dedicado.',
  },
  {
    num: '03',
    eyebrow: 'Método',
    title: 'Cómo trabajamos',
    body: 'Nuestro método se llama Diagnóstico · Estrategia · Implementación · Seguimiento · Resultados. No vendemos PPTs: nos comprometemos a operar. No prometemos lo imposible: trabajamos sobre lo posible para hacerlo realidad.',
  },
  {
    num: '04',
    eyebrow: 'Red',
    title: 'Dónde estamos',
    body: 'Sede central en Santiago, Chile. Operación nacional con presencia activa en regiones, de Arica a Punta Arenas. Conexión con federaciones, marcas y fondos relevantes para el deporte chileno.',
  },
];
---

<Base
  title="Nosotros — Quiénes somos en GSM"
  description="GSM (Game · Set...Match) es la agencia chilena de gestión deportiva integral fundada hace 12 años. Conoce nuestro equipo, valores y metodología."
  breadcrumbs={breadcrumbs}
>
  <section class="page-hero bg-ink">
    <div class="container-x">
      <p class="eyebrow">Nosotros · GSM</p>
      <h1 class="page-hero__title font-display-narrow" data-split>
        Una agencia chilena <em class="font-serif-italic text-orange">para el deporte</em> que viene.
      </h1>
      <p class="page-hero__lead">
        GSM nace de una convicción simple: el deporte chileno tiene talento, pasión y pasta para competir con cualquiera. Lo que falta no es esfuerzo: es estructura, método y red. Eso es lo que GSM aporta.
      </p>
    </div>
  </section>

  <section class="manifest-section bg-bone">
    <Marquee items={['12 años', '247+ atletas', '38 sponsors', 'Operación nacional', 'Una sola visión']} duration={50} />
    <div class="container-x manifest-wrap">
      <header class="manifest-head">
        <span class="eyebrow">Manifiesto</span>
        <h2 class="manifest-title font-display-narrow" data-split>
          Una agencia, <em class="font-serif-italic text-orange">cuatro convicciones</em>.
        </h2>
        <p class="manifest-lead">
          GSM se construye sobre una idea simple y cuatro pilares concretos. Esto es lo que somos, lo que hacemos, cómo lo hacemos y desde dónde lo hacemos.
        </p>
      </header>

      <div class="manifest-grid">
        {manifestBlocks.map((b, i) => (
          <article class="manifest-card" data-reveal style={`--reveal-delay:${i * 120}ms`}>
            <div class="manifest-card__top">
              <span class="manifest-card__num font-display-narrow">{b.num}</span>
              <span class="manifest-card__eye font-mono">{b.eyebrow}</span>
            </div>
            <h3 class="manifest-card__title font-display-narrow">{b.title}</h3>
            <p class="manifest-card__body">{b.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Founders />

  <section class="values bg-ink">
    <div class="container-x">
      <header class="values__head">
        <p class="eyebrow">Valores</p>
        <h2 class="values__title font-display-narrow" data-split>Cuatro reglas <em class="font-serif-italic text-orange">no negociables</em>.</h2>
      </header>
      <div class="values__grid">
        {values.map((v, i) => (
          <div class="value-card" data-reveal style={`--reveal-delay:${i * 120}ms`}>
            <p class="value-card__num font-display">{v.num}</p>
            <h3 class="value-card__title font-display-narrow">{v.title}</h3>
            <p>{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="us-stats bg-court-deep">
    <div class="container-x">
      <p class="eyebrow" data-reveal>En números</p>
      <div class="us-stats__grid">
        {STATS.map((s, i) => (
          <div class="us-stat" data-reveal style={`--reveal-delay:${i * 100}ms`}>
            <p class="us-stat__num font-display-narrow"><span data-counter={s.value} data-suffix={s.suffix}>0{s.suffix}</span></p>
            <p class="us-stat__label">{s.label}</p>
            <p class="us-stat__sub font-mono">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .page-hero { padding-block: calc(var(--spacing-section) + 3.5rem) calc(var(--spacing-section) - 1rem); }
    .page-hero__title { font-size: clamp(1.7rem, 3.2vw, 2.8rem); line-height: 1.15; letter-spacing: -0.02em; margin: 0.8rem 0 1.2rem; max-width: 26ch; }
    .page-hero__lead { max-width: 62ch; color: rgba(242,239,232,0.78); font-size: 0.95rem; line-height: 1.6; }

    .manifest-section { padding-block: var(--spacing-section); color: var(--color-ink); overflow: hidden; }
    .manifest-wrap { margin-top: clamp(2.5rem, 5vw, 4rem); }
    .manifest-head { max-width: 52rem; margin: 0 auto clamp(2.5rem, 5vw, 4rem); display: grid; gap: 0.9rem; text-align: center; justify-items: center; }
    .manifest-head .eyebrow { color: var(--color-orange); }
    .manifest-title { font-size: clamp(1.5rem, 2.6vw, 2.4rem); line-height: 1.15; letter-spacing: -0.02em; margin: 0; max-width: 22ch; }
    .manifest-lead { max-width: 56ch; color: rgba(10,10,10,0.72); font-size: 0.95rem; line-height: 1.6; margin: 0; }

    .manifest-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: clamp(1rem, 2vw, 1.6rem);
      max-width: 64rem;
      margin: 0 auto;
    }
    @media (max-width: 800px) { .manifest-grid { grid-template-columns: 1fr; } }
    .manifest-card {
      background: var(--color-paper);
      border: 1px solid rgba(10,10,10,0.08);
      padding: 1.6rem 1.5rem 1.6rem;
      display: grid;
      gap: 0.75rem;
    }
    .manifest-card__top { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
    .manifest-card__num { font-size: 1.8rem; line-height: 0.95; letter-spacing: -0.02em; color: var(--color-orange); }
    .manifest-card__eye { font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; opacity: 0.6; }
    .manifest-card__title { font-size: clamp(1.1rem, 1.5vw, 1.35rem); line-height: 1.2; letter-spacing: -0.015em; margin: 0.1rem 0 0; }
    .manifest-card__body { font-size: 0.92rem; line-height: 1.6; color: rgba(10,10,10,0.78); margin: 0; }

    .values { padding-block: var(--spacing-section); }
    .values__head { display: grid; gap: 0.9rem; margin-bottom: clamp(2.5rem, 5vw, 4rem); max-width: 52rem; }
    .values__title { font-size: clamp(1.5rem, 2.6vw, 2.4rem); letter-spacing: -0.02em; margin: 0; line-height: 1.15; }
    .values__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
    @media (max-width: 1000px) { .values__grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .values__grid { grid-template-columns: 1fr; } }
    .value-card { padding: 1.6rem 1.3rem; background: rgba(242,239,232,0.03); border: 1px solid var(--color-line); display: grid; gap: 0.5rem; min-height: 16rem; }
    .value-card__num { font-size: 2.2rem; line-height: 0.9; color: var(--color-orange); margin: 0; }
    .value-card__title { font-size: 1.05rem; letter-spacing: -0.015em; margin: 0; }
    .value-card p { color: rgba(242,239,232,0.78); margin: 0; font-size: 0.92rem; }

    .us-stats { padding-block: var(--spacing-section); }
    .us-stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border-top: 1px solid var(--color-line); border-bottom: 1px solid var(--color-line); margin-top: 1rem; }
    @media (max-width: 900px) { .us-stats__grid { grid-template-columns: repeat(2, 1fr); } }
    .us-stat { padding: 2rem 1.2rem 1.6rem; border-right: 1px solid var(--color-line); display: grid; gap: 0.4rem; }
    .us-stat:last-child { border-right: 0; }
    @media (max-width: 900px) { .us-stat:nth-child(2) { border-right: 0; } }
    .us-stat__num { font-size: clamp(2rem, 3.6vw, 3.2rem); line-height: 0.95; letter-spacing: -0.03em; color: var(--color-orange); margin: 0; }
    .us-stat__label { font-size: 0.95rem; font-weight: 600; margin: 0; }
    .us-stat__sub { font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.7; margin: 0; }
  </style>
</Base>
