---
import { waLink, WHATSAPP_MESSAGES } from '../../lib/site';
---

<a
  class="wa-float"
  href={waLink(WHATSAPP_MESSAGES.default)}
  target="_blank"
  rel="noopener"
  aria-label="Escribir a GSM por WhatsApp"
  data-magnetic
  data-magnetic-strength="10"
>
  <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" fill="currentColor">
    <path d="M19.05 4.91A10 10 0 0 0 4.34 18.36L3 22l3.74-1.31A10 10 0 1 0 19.05 4.91Zm-7 15.34a8.32 8.32 0 0 1-4.24-1.16l-.3-.18-2.22.78.73-2.16-.2-.32a8.32 8.32 0 1 1 6.23 3.04Zm4.55-6.23c-.25-.13-1.47-.72-1.7-.8s-.4-.13-.56.13-.65.8-.79.97-.29.19-.54.06a6.83 6.83 0 0 1-2-1.23 7.5 7.5 0 0 1-1.4-1.74c-.14-.25 0-.39.11-.51s.25-.29.38-.43a1.7 1.7 0 0 0 .25-.42.47.47 0 0 0 0-.43c-.06-.12-.56-1.34-.76-1.83s-.4-.42-.56-.43h-.48a.91.91 0 0 0-.66.31 2.78 2.78 0 0 0-.86 2.06c0 1.21.88 2.39 1 2.55a9.8 9.8 0 0 0 3.84 3.4 13 13 0 0 0 1.28.47 3.08 3.08 0 0 0 1.42.09 2.32 2.32 0 0 0 1.52-1.07 1.88 1.88 0 0 0 .13-1.07c-.06-.1-.22-.16-.47-.29Z" />
  </svg>
  <span class="wa-float__label">WhatsApp</span>
</a>

<style>
  .wa-float {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 70;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: #25D366;
    color: #0a0a0a;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
    box-shadow: 0 10px 30px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.05);
    transition: transform 0.4s var(--ease-out-expo);
  }
  .wa-float:hover { background: #20bd5b; }
  @media (max-width: 600px) {
    .wa-float { padding: 0.65rem; }
    .wa-float__label { display: none; }
  }
</style>
