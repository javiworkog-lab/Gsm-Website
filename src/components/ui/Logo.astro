---
interface Props {
  variant?: 'orange' | 'white' | 'green' | 'mono';
  withTagline?: boolean;
  class?: string;
  size?: number;
}
const { variant = 'white', class: cls = '', size = 56 } = Astro.props;

// Mapeo a archivos PNG y modo de mezcla según el fondo donde irá:
// - 'white'  → logo blanco (sobre fondos oscuros) → screen apaga el fondo negro del PNG
// - 'orange' → logo a color (sobre fondos claros) → multiply apaga el fondo blanco del PNG
const isOnDark = variant === 'white' || variant === 'mono';
const src = isOnDark ? '/logo-white.png' : '/logo-color.png';
const blend = isOnDark ? 'screen' : 'multiply';

// Aspect ratios reales:
// logo-color.png: 866 × 608  (≈ 1.42)
// logo-white.png: 1040 × 494 (≈ 2.10)
const aspect = isOnDark ? 1040 / 494 : 866 / 608;
const width = Math.round(size * aspect);
---

<a href="/" aria-label="GSM — Game Set Match — Inicio" class={`gsm-logo inline-flex items-center ${cls}`}>
  <img
    src={src}
    alt="GSM — Game · Set...Match"
    width={width}
    height={size}
    style={`display:block;height:${size}px;width:auto;mix-blend-mode:${blend};`}
    loading="eager"
    decoding="async"
  />
</a>
