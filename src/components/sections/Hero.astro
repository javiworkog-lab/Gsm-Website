---
import { waLink, WHATSAPP_MESSAGES } from '../../lib/site';
---

<section class="hero" id="hero">
  <!-- Video de fondo (con fallback estático) -->
  <div class="hero__bg" aria-hidden="true">
    <video
      class="hero__video"
      src="/video/hero-tennis.mp4"
      poster="/images/hero-tennis.jpg"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
    ></video>
    <div class="hero__overlay"></div>
    <div class="hero__noise"></div>
  </div>

  <!-- Macro letter watermark -->
  <div class="hero__macro" aria-hidden="true"><span>M</span></div>

  <div class="container-x hero__inner">
    <h1 class="hero__title font-display-narrow">
      <span class="hero__line"><span data-hero-line>EL DEPORTE</span></span>
      <span class="hero__line"><span data-hero-line>NO SE</span> <em class="font-serif-italic text-orange" data-hero-line>improvisa</em>.</span>
      <span class="hero__line"><span data-hero-line>SE GESTIONA.</span></span>
    </h1>

    <p class="hero__sub" data-hero-sub>
      Somos GSM. La agencia chilena que convierte talento deportivo en carrera, y carrera en legado. Para atletas que viven del deporte y para las instituciones que lo sostienen: clubes, federaciones, fundaciones, colegios y universidades.
    </p>

    <div class="hero__cta">
      <a class="btn btn-primary" data-magnetic data-hero-cta href={waLink(WHATSAPP_MESSAGES.hero)} target="_blank" rel="noopener">
        Conversemos
      </a>
      <a class="btn btn-outline" data-magnetic data-hero-cta href="/servicios">
        Ver servicios →
      </a>
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: clamp(6rem, 11vh, 8rem) clamp(4rem, 10vh, 7rem);
    overflow: hidden;
    color: var(--color-bone);
    background: var(--color-ink);
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__bg img, .hero__video {
    width: 100%; height: 100%; object-fit: cover;
    filter: contrast(1.05) saturate(0.95);
    transform: scale(1.04);
  }
  .hero__video { position: absolute; inset: 0; }
  .hero__overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(10,10,10,0.35) 0%, rgba(10,10,10,0.15) 40%, rgba(10,10,10,0.85) 100%),
      linear-gradient(90deg, rgba(10,10,10,0.6) 0%, rgba(10,10,10,0.15) 50%, rgba(10,10,10,0.3) 100%);
  }
  .hero__noise {
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.85'/%3E%3C/svg%3E");
    opacity: 0.08;
    mix-blend-mode: overlay;
  }
  .hero__macro {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    overflow: hidden;
  }
  .hero__macro span {
    font-family: var(--font-display);
    font-weight: 800;
    font-style: italic;
    font-size: clamp(28rem, 70vmin, 60rem);
    line-height: 0.78;
    letter-spacing: -0.06em;
    color: var(--color-bone);
    opacity: 0.04;
    transform: translateX(15%) rotate(-6deg);
    user-select: none;
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
  }
  .hero__meta {
    display: flex; align-items: center; justify-content: space-between; gap: 2rem;
    margin-bottom: clamp(2rem, 5vw, 4rem);
    flex-wrap: wrap;
  }
  .hero__counter {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.32em;
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
  }
  .hero__title {
    font-size: clamp(2rem, 5.2vw, 4.4rem);
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    margin: 0 0 1.4rem;
    max-width: 20ch;
  }
  .hero__line {
    display: block;
    overflow: hidden;
  }
  .hero__line > span, .hero__line > em { display: inline-block; }
  .hero__line em { transform: translateY(0.05em); }
  .hero__sub {
    max-width: 58ch;
    font-size: clamp(0.95rem, 0.95vw, 1.05rem);
    line-height: 1.5;
    color: rgba(242, 239, 232, 0.78);
    margin: 0 0 1.8rem;
  }
  .hero__cta { display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .hero__scroll {
    position: absolute;
    right: var(--spacing-gutter);
    bottom: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    opacity: 0.55;
  }
  .hero__scroll-line {
    display: inline-block;
    width: 60px;
    height: 1px;
    background: currentColor;
    position: relative;
    overflow: hidden;
  }
  .hero__scroll-line::after {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 24px; height: 100%;
    background: var(--color-orange);
    animation: scrollPulse 1.8s var(--ease-in-out-expo) infinite;
  }
  @keyframes scrollPulse {
    0% { transform: translateX(-100%); }
    50% { transform: translateX(200%); }
    100% { transform: translateX(200%); }
  }
  @media (max-width: 600px) {
    .hero__scroll { display: none; }
    .hero__title { line-height: 0.92; }
  }
</style>
