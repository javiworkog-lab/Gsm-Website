---
const founders = [
  {
    name: 'Robinson Gamonal',
    role: 'CEO de GSM',
    img: '/images/team/robinson-gamonal.jpg',
    bio: 'Lleva más de 20 años metido en el deporte chileno. Le mueve abrir puertas para atletas y conectar a los proyectos con la gente que los hace crecer.',
    objectPos: 'center top',
    baseScale: 1,
    baseTranslateY: '0%',
    mediaBg: '#1a1a1a',
  },
  {
    name: 'Andrea Gamonal Loyer',
    role: 'Socia Fundadora · Abogada',
    img: '/images/team/andrea-gamonal.jpg',
    bio: 'Abogada de profesión y socia fundadora. Acompaña a atletas e instituciones en cada contrato y trato, cuidando que todo quede claro y bien hecho.',
    objectPos: 'center top',
    baseScale: 1,
    baseTranslateY: '0%',
    mediaBg: '#1a1a1a',
  },
  {
    name: 'Eduardo Montecinos',
    role: 'Desarrollador Estratégico',
    img: '/images/team/eduardo-montecinos.jpg',
    bio: 'Le gusta tomar una idea y volverla un proyecto real. Arma alianzas, busca fondos y abre caminos nuevos para que GSM siga creciendo.',
    objectPos: 'center 28%',
    baseScale: 1,
    baseTranslateY: '0%',
    mediaBg: '#ffffff',
  },
  {
    name: 'Carmen Luisa Gamonal Loyer',
    role: 'Gerente de Operaciones',
    img: '/images/team/carmen-luisa-gamonal.jpg',
    bio: 'Es la que mantiene todo funcionando: programas, agendas y la coordinación con cada institución. Sin ella, GSM no anda.',
    objectPos: 'center 28%',
    baseScale: 1,
    baseTranslateY: '0%',
    mediaBg: '#0a0a0a',
  },
];
---

<section class="founders bg-bone" id="fundadores">
  <div class="container-x">
    <header class="founders__head">
      <span class="eyebrow" data-reveal>Equipo fundador</span>
      <h2 class="founders__title font-display-narrow" data-split>
        Hecho por quienes <em class="font-serif-italic text-orange">vivieron</em> el deporte.
      </h2>
      <p class="founders__lead" data-reveal style="--reveal-delay:160ms">
        GSM nace de la trayectoria de Andrea y Robinson Gamonal: dos vidas dedicadas al deporte, a la gestión y a las personas que lo sostienen. La agencia es la suma de esa experiencia con una metodología clara.
      </p>
    </header>

    <div class="founders__grid">
      {founders.map((f, i) => (
        <article class="founder" data-reveal style={`--reveal-delay:${i * 140}ms`}>
          <div class="founder__media" style={f.mediaBg ? `background:${f.mediaBg}` : undefined}>
            <img src={f.img} alt={`Retrato de ${f.name}, ${f.role}`} loading="lazy" decoding="async" style={`object-position: ${f.objectPos}; --base-scale: ${f.baseScale}; --base-ty: ${f.baseTranslateY};`} />
          </div>
          <div class="founder__body">
            <p class="founder__role font-mono">{f.role}</p>
            <h3 class="founder__name font-display-narrow">{f.name}</h3>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .founders {
    padding-block: var(--spacing-section);
    color: var(--color-ink);
    position: relative;
    overflow: hidden;
  }
  .founders__head {
    max-width: 52rem;
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
    display: grid;
    gap: 0.9rem;
  }
  .founders__title {
    font-size: clamp(1.5rem, 2.6vw, 2.4rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 22ch;
  }
  .founders__lead {
    max-width: 58ch;
    color: rgba(10,10,10,0.72);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .founders__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(0.9rem, 1.6vw, 1.4rem);
    max-width: 100%;
    margin-inline: auto;
  }
  @media (max-width: 1100px) { .founders__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .founders__grid { grid-template-columns: 1fr; } }

  .founder {
    display: grid;
    gap: 0.95rem;
    background: var(--color-paper);
    border: 1px solid rgba(10,10,10,0.08);
    padding: 1.1rem 1.1rem 1.3rem;
  }
  .founder__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-ink-2, #1a1a1a);
  }
  .founder__media img {
    --base-scale: 1;
    --base-ty: 0%;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    transform: scale(var(--base-scale)) translateY(var(--base-ty));
    transform-origin: center top;
    filter: grayscale(1) contrast(1.05);
    transition: transform 0.8s var(--ease-out-expo), filter 0.5s ease;
  }
  .founder:hover .founder__media img {
    transform: scale(calc(var(--base-scale) * 1.03)) translateY(var(--base-ty));
    filter: grayscale(1) contrast(1.08);
  }
  .founder__body { display: grid; gap: 0.5rem; }
  .founder__role {
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin: 0;
  }
  .founder__name {
    font-size: clamp(1.05rem, 1.25vw, 1.3rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .founder__bio {
    font-size: 0.85rem;
    line-height: 1.55;
    color: rgba(10,10,10,0.78);
    margin: 0.2rem 0 0;
  }
</style>
