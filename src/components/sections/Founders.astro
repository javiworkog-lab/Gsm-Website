---
const founders = [
  {
    name: 'Robinson Gamonal',
    role: 'CEO de GSM',
    img: '/images/team/robinson-gamonal.jpg',
    bio: 'Ex jugador ATP y Copa Davis. Coach de alto rendimiento con más de 400 atletas formados, varios con ranking ATP y WTA. Socio fundador de Sport Academy y Colegio Olimpo.',
    objectPos: 'center top',
    baseScale: 1,
    baseTranslateY: '0%',
    mediaBg: '#1a1a1a',
  },
  {
    name: 'Andrea Gamonal Loyer',
    role: 'Socia Fundadora · Abogada',
    img: '/images/team/andrea-gamonal.jpg',
    bio: 'Abogada y socia fundadora de estudio jurídico. Especializada en defensa penal, protección de marcas y asesoría corporativa para empresas nacionales e internacionales. Diplomado en Derecho Tributario UNAB.',
    objectPos: 'center top',
    baseScale: 1,
    baseTranslateY: '0%',
    mediaBg: '#1a1a1a',
  },
  {
    name: 'Eduardo Montecinos',
    role: 'Desarrollador Estratégico',
    img: '/images/team/eduardo-montecinos.jpg',
    bio: 'Desarrollador estratégico con trayectoria en alianzas corporativas, levantamiento de fondos y patrocinios deportivos. Convierte ideas en proyectos estructurados, financiables y medibles.',
    objectPos: 'center 28%',
    baseScale: 1,
    baseTranslateY: '0%',
    mediaBg: '#ffffff',
  },
  {
    name: 'Carmen Luisa Gamonal Loyer',
    role: 'Gerente de Operaciones',
    img: '/images/team/carmen-luisa-gamonal.jpg',
    bio: 'Ingeniera en Administración de Empresas con más de 30 años en gestión de servicio al cliente y operaciones de Contact Center. Liderazgo de equipos, calidad y mejora continua de procesos.',
    objectPos: 'center 28%',
    baseScale: 1,
    baseTranslateY: '0%',
    mediaBg: '#0a0a0a',
  },
  {
    name: 'Javiera Ortiz Gamonal',
    role: 'Software Developer · Producto',
    img: '/images/team/javiera-ortiz-gamonal.jpg',
    bio: 'Ingeniera Comercial (MBA) con 9 años de formación y trayectoria profesional en Estados Unidos. +4 años trabajando con SaaS, automatización CRM y desarrollo de producto digital. Lidera la plataforma GSM.',
    objectPos: 'center 22%',
    baseScale: 1,
    baseTranslateY: '0%',
    mediaBg: '#1a1a1a',
  },
];
---

<section class="founders bg-bone" id="fundadores">
  <div class="container-x">
    <header class="founders__head">
      <span class="eyebrow" data-reveal>Equipo fundador</span>
      <h2 class="founders__title font-display-narrow" data-split>
        Cuatro miradas, <em class="font-serif-italic text-orange">una sola</em> metodología.
      </h2>
      <p class="founders__lead" data-reveal style="--reveal-delay:160ms">
        GSM es un equipo multidisciplinario: trayectoria en cancha y gestión deportiva, mirada legal, desarrollo estratégico y operaciones. Cuatro perfiles complementarios que se ordenan en una sola forma de trabajar para que los proyectos no dependan de la pasión, sino del método.
      </p>
    </header>

    <div class="founders__grid">
      {founders.map((f, i) => (
        <article class="founder" data-reveal style={`--reveal-delay:${i * 140}ms`}>
          <div class="founder__media" style={f.mediaBg ? `background:${f.mediaBg}` : undefined}>
            <img src={f.img} alt={`Retrato de ${f.name}, ${f.role}`} loading="lazy" decoding="async" style={`object-position: ${f.objectPos}; --base-scale: ${f.baseScale}; --base-ty: ${f.baseTranslateY};`} />
          </div>
          <div class="founder__body">
            <p class="founder__role font-mono">{f.role}</p>
            <h3 class="founder__name font-display-narrow">{f.name}</h3>
            <p class="founder__bio">{f.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .founders {
    padding-block: var(--spacing-section);
    color: var(--color-ink);
    position: relative;
    overflow: hidden;
  }
  .founders__head {
    max-width: 52rem;
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
    display: grid;
    gap: 0.9rem;
  }
  .founders__title {
    font-size: var(--title-h2);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 22ch;
  }
  .founders__lead {
    max-width: 58ch;
    color: rgba(10,10,10,0.72);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .founders__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: clamp(0.8rem, 1.4vw, 1.2rem);
    max-width: 100%;
    margin-inline: auto;
  }
  @media (max-width: 1280px) { .founders__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 800px)  { .founders__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px)  { .founders__grid { grid-template-columns: 1fr; } }

  .founder {
    display: grid;
    gap: 0.95rem;
    background: var(--color-paper);
    border: 1px solid rgba(10,10,10,0.08);
    padding: 1.1rem 1.1rem 1.3rem;
  }
  .founder__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-ink-2, #1a1a1a);
  }
  .founder__media img {
    --base-scale: 1;
    --base-ty: 0%;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    transform: scale(var(--base-scale)) translateY(var(--base-ty));
    transform-origin: center top;
    filter: grayscale(1) contrast(1.05);
    transition: transform 0.8s var(--ease-out-expo), filter 0.5s ease;
  }
  .founder:hover .founder__media img {
    transform: scale(calc(var(--base-scale) * 1.03)) translateY(var(--base-ty));
    filter: grayscale(1) contrast(1.08);
  }
  .founder__body { display: grid; gap: 0.5rem; }
  .founder__role {
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin: 0;
  }
  .founder__name {
    font-size: var(--title-h3);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .founder__bio {
    font-size: 0.85rem;
    line-height: 1.55;
    color: rgba(10,10,10,0.78);
    margin: 0.2rem 0 0;
  }
</style>
