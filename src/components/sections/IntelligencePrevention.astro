---
import { waLink, WHATSAPP_MESSAGES } from '../../lib/site';

const pillars = [
  {
    num: '01',
    name: 'Lectura de datos',
    body: 'Una metodología para ordenar e interpretar los registros que el atleta ya genera en sus evaluaciones clínicas.',
  },
  {
    num: '02',
    name: 'Señales tempranas',
    body: 'Detección de patrones que ameriten ajuste de carga, descanso o derivación al equipo médico tratante.',
  },
  {
    num: '03',
    name: 'Decisiones de carrera',
    body: 'Un informe accionable que sirve al atleta, a su cuerpo técnico y a su club para planificar mejor.',
  },
];

const audiences = [
  { tag: 'Atleta', body: 'Más información para cuidar el cuerpo en el largo plazo.' },
  { tag: 'Cuerpo técnico', body: 'Decisiones de carga apoyadas en evidencia, no en intuición.' },
  { tag: 'Club · Institución', body: 'Continuidad del proyecto deportivo y menos tiempo fuera por lesión.' },
];
---

<section class="prev bg-court-deep" id="prevencion">
  <div class="prev__lines" aria-hidden="true">
    <svg viewBox="0 0 1200 220" preserveAspectRatio="none">
      <path d="M0,160 C150,120 250,180 400,140 C560,98 680,170 820,130 C960,92 1080,150 1200,118" fill="none" stroke="rgba(198,96,51,0.22)" stroke-width="1" />
      <path d="M0,180 C160,150 280,200 440,160 C600,118 720,190 880,150 C1020,118 1120,170 1200,140" fill="none" stroke="rgba(242,239,232,0.10)" stroke-width="1" />
      <path d="M0,140 C140,100 260,160 420,120 C580,80 700,150 860,110 C1000,72 1100,130 1200,100" fill="none" stroke="rgba(242,239,232,0.06)" stroke-width="1" />
    </svg>
  </div>

  <div class="container-x prev__container">
    <header class="prev__head">
      <span class="eyebrow font-mono" data-reveal>Proyecto en desarrollo · Inteligencia preventiva</span>
      <h2 class="prev__title font-display-narrow" data-split>
        Prevenir lesiones <br />
        no es suerte. <br />
        Es <em class="font-serif-italic text-orange">leer los datos</em>.
      </h2>
      <p class="prev__lead" data-reveal style="--reveal-delay:160ms">
        Estamos construyendo un módulo de análisis preventivo: una capa de lectura sobre la información médico-deportiva del atleta, pensada para anticiparse al desgaste y cuidar la carrera en el tiempo.
      </p>
    </header>

    <div class="prev__pillars">
      {pillars.map((p, i) => (
        <article class="pillar" data-reveal style={`--reveal-delay:${i * 130}ms`}>
          <p class="pillar__num font-display-narrow">{p.num}</p>
          <h3 class="pillar__name font-mono">{p.name}</h3>
          <p class="pillar__body">{p.body}</p>
        </article>
      ))}
    </div>

    <div class="prev__audience">
      {audiences.map((a, i) => (
        <article class="aud" data-reveal style={`--reveal-delay:${i * 110}ms`}>
          <p class="aud__tag font-mono">{a.tag}</p>
          <p class="aud__body">{a.body}</p>
        </article>
      ))}
    </div>

    <aside class="prev__scope" data-reveal>
      <p class="prev__scope-eye font-mono">Sobre el alcance</p>
      <p class="prev__scope-body">
        <strong>GSM no es una clínica.</strong> No diagnostica, no indica tratamiento, no reemplaza al equipo médico del atleta. El módulo es una capa de análisis e interpretación que se apoya siempre en el criterio clínico del profesional tratante.
      </p>
    </aside>

    <div class="prev__cta">
      <a class="btn btn-primary" data-magnetic href={waLink(WHATSAPP_MESSAGES.prevention)} target="_blank" rel="noopener"
         aria-label="Hablar con GSM por WhatsApp sobre el módulo de prevención en desarrollo">
        Conversemos del proyecto →
      </a>
      <p class="prev__foot font-mono">En desarrollo · Disponibilidad y alcance se confirman caso a caso.</p>
    </div>
  </div>
</section>

<style>
  .prev {
    padding-block: var(--spacing-section);
    position: relative;
    overflow: hidden;
    color: var(--color-bone);
  }
  .prev__lines {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .prev__lines svg {
    width: 100%;
    height: 100%;
    position: absolute;
    bottom: 0;
    left: 0;
  }
  .prev__container { position: relative; z-index: 1; }

  .prev__head {
    max-width: 60rem;
    display: grid;
    gap: 1.1rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .prev__head .eyebrow { color: var(--color-orange); }
  .prev__title {
    font-size: var(--title-h2);
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin: 0;
    max-width: 22ch;
  }
  .prev__lead {
    max-width: 58ch;
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.78;
    margin: 0;
  }

  .prev__pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    margin-bottom: clamp(2.5rem, 4vw, 3.5rem);
  }
  @media (max-width: 900px) { .prev__pillars { grid-template-columns: 1fr; } }
  .pillar {
    padding: 2rem 1.6rem 1.8rem;
    border-right: 1px solid var(--color-line);
    display: grid;
    gap: 0.7rem;
    align-content: start;
  }
  .pillar:last-child { border-right: 0; }
  @media (max-width: 900px) {
    .pillar { border-right: 0; border-bottom: 1px solid var(--color-line); }
    .pillar:last-child { border-bottom: 0; }
  }
  .pillar__num {
    font-size: clamp(2rem, 3.2vw, 2.8rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-orange);
    margin: 0;
  }
  .pillar__name {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.85;
    margin: 0;
  }
  .pillar__body {
    font-size: 0.95rem;
    line-height: 1.55;
    opacity: 0.78;
    margin: 0;
    max-width: 32ch;
  }

  .prev__audience {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: clamp(2rem, 3vw, 2.8rem);
  }
  @media (max-width: 700px) { .prev__audience { grid-template-columns: 1fr; } }
  .aud {
    padding: 1.3rem 1.2rem;
    border: 1px solid var(--color-line);
    background: rgba(242,239,232,0.025);
    display: grid;
    gap: 0.45rem;
  }
  .aud__tag {
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin: 0;
  }
  .aud__body { font-size: 0.92rem; line-height: 1.5; opacity: 0.82; margin: 0; }

  .prev__scope {
    max-width: 56rem;
    border-left: 2px solid var(--color-orange);
    padding: 0.9rem 0 0.9rem 1.2rem;
    margin-bottom: clamp(2rem, 3.5vw, 3rem);
  }
  .prev__scope-eye {
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.65;
    margin: 0 0 0.5rem;
  }
  .prev__scope-body {
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    opacity: 0.88;
  }
  .prev__scope-body strong { color: var(--color-bone); font-weight: 600; }

  .prev__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.4rem;
  }
  .prev__foot {
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.55;
    margin: 0;
  }
</style>
